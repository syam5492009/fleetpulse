# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=fleetpulse
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=fleetpulse

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fleetpulse:changeme_in_production@localhost:5432/fleetpulse
REDIS_URL=redis://localhost:6379
MQTT_BROKER=mqtt://localhost:1883
PORT=3001

# Restrict CORS to your frontend origin (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Optional — only needed if you switch tile provider to Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=
